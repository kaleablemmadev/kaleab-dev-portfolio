<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ✅ App Basic Info -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    
    <key>CFBundleDisplayName</key>
    <string>Misol Calendar</string>
    
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    
    <key>CFBundleName</key>
    <string>misol</string>
    
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    
    <key>CFBundleSignature</key>
    <string>????</string>
    
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    
    <key>LSRequiresIPhoneOS</key>
    <true/>
    
    <!-- ✅ UI Configuration -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>
    
    <!-- ✅ Launch Screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    
    <!-- ✅ Permissions -->
    <!-- Notifications -->
    <key>NSUserNotificationsUsageDescription</key>
    <string>Misol Calendar needs permission to send you event reminders and notifications so you never miss an important event.</string>
    
    <!-- Calendar Access (Optional - if you want to sync with iOS Calendar) -->
    <key>NSCalendarsUsageDescription</key>
    <string>Misol Calendar would like to access your calendar to sync events.</string>
    
    <!-- Reminders Access (Optional) -->
    <key>NSRemindersUsageDescription</key>
    <string>Misol Calendar would like to access your reminders to help you stay organized.</string>
    
    <!-- ✅ Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
        <string>remote-notification</string>
        <string>processing</string>
    </array>
    
    <!-- ✅ Audio Session for Ringtones -->
    <key>AVAudioSessionCategory</key>
    <string>AVAudioSessionCategoryPlayback</string>
    
    <key>AVAudioSessionMode</key>
    <string>AVAudioSessionModeDefault</string>
    
    <!-- ✅ App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    
    <!-- ✅ Flutter Integration -->
    <key>FlutterDeepLinkingEnabled</key>
    <true/>
    
    <!-- ✅ DidFinishLaunchingWithOptions -->
    <key>UIApplicationLaunchOptionsKey</key>
    <string>UIApplicationLaunchOptionsKey</string>
    
    <!-- ✅ Local Notifications -->
    <key>UILocalNotification</key>
    <dict>
        <key>alert</key>
        <string>Misol Calendar needs permission to send you reminders for your events.</string>
    </dict>
    
    <!-- ✅ Push Notifications -->
    <key>aps-environment</key>
    <string>development</string>
    
    <!-- ✅ Custom URL Schemes (Optional) -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>misol</string>
            </array>
        </dict>
    </array>
    
    <!-- ✅ App Icon (Override) -->
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon</string>
            </array>
        </dict>
    </dict>
    
    <!-- ✅ About/Support Information -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2024 Misol. All rights reserved.</string>
    
    <!-- ✅ Network Connectivity (for connectivity_plus) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Misol Calendar needs local network access to check connectivity status.</string>
</dict>
</plist>